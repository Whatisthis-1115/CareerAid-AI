FLASK_ENV=development
SECRET_KEY=dev-secret-change-me

# Spark (讯飞星火) / LLM 配置（可选）
AI_PROVIDER=spark
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=
SPARK_MODEL=

# 通用 OpenAI-兼容接口（可选）
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=

# 火山引擎（火山方舟/豆包）大模型 API 预留。设置 AI_PROVIDER=volc 时生效
# 文档：https://www.volcengine.com/docs/82379/
VOLC_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLC_API_KEY=d99c573d-6e23-4ba4-aba7-3f4237a680ff
VOLC_MODEL=doubao-seed-2-0-pro-260215
# 是否启用联网搜索（当前为简易抓取兜底；如接入方舟 Web Search 工具可替换实现）
VOLC_ENABLE_WEB_SEARCH=true
# 若方舟控制台提供的是 OpenAI 兼容端点，也可用 OPENAI_* 并设 AI_PROVIDER=openai_compatible
